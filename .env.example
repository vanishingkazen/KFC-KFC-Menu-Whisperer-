# LLM 配置
# 提供商: openai | anthropic
LLM_PROVIDER=openai

# 模型名称
LLM_MODEL=deepseek-chat

# API 地址（可选，用于代理或本地部署）
LLM_BASE_URL=https://api.deepseek.com
# LLM_BASE_URL=https://your-proxy.com/v1

# API Key
LLM_API_KEY=sk-871e01a0efd646f5823439d7432ec3a0

# 温度参数
LLM_TEMPERATURE=0.7

# 召回配置
MAX_CANDIDATES=60
LOWER_EXPAND=150
UPPER_EXPAND=100

# 核验配置
VALIDATION_TIMEOUT_MS=3000
MAX_CONCURRENCY=20

# 路由配置
FALLBACK_THRESHOLD=1
FALLBACK_RATIO=0.5
FALLBACK_MIN_MATCH=2

# 生成配置
TOP_K=5